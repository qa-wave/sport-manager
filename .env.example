## ----- Database -----
DATABASE_URL="postgresql://sport_manager:sport_manager@localhost:5432/sport_manager?schema=public"

## ----- Redis -----
REDIS_URL="redis://localhost:6379"

## ----- Runtime -----
NODE_ENV="development"
PORT=3100

## ----- JWT -----
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

## ----- App URLs -----
## Public URL used for magic links, emails, etc.
NEXT_PUBLIC_APP_URL="http://localhost:3100"
## Web FE volá API same-origin, takže nic nastavovat netřeba.
## Expo potřebuje plnou URL — přepiš na tunel/LAN adresu Next dev serveru.
NEXT_PUBLIC_API_URL="http://localhost:3100/api/v1"
EXPO_PUBLIC_API_URL="http://localhost:3100/api/v1"

## ----- CORS -----
## Comma-separated list of allowed origins (production).
CORS_ORIGIN="https://sport-manager.qawave.ai"

## ----- Stripe -----
## https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

## ----- Resend (email) -----
## https://resend.com/api-keys
RESEND_API_KEY=""
## From address used for outgoing emails.
RESEND_FROM_EMAIL="Sport Manager <noreply@sport-manager.qawave.ai>"

## ----- Web Push / VAPID -----
## Generate keys: bash scripts/generate-vapid-keys.sh
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@sport-manager.qawave.ai"

## ----- Vercel Blob (file uploads) -----
## https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=""

## ----- Cron jobs -----
## Secret token to authenticate cron job requests from Vercel.
CRON_SECRET=""

## ----- Football data API -----
## https://www.api-football.com — for AI Liga Sync (future feature)
API_FOOTBALL_KEY=""

## ----- Sentry (error tracking) -----
## https://sentry.io — DSN from project settings
NEXT_PUBLIC_SENTRY_DSN=""
