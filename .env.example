## ----- Database -----
DATABASE_URL="postgresql://sport_manager:sport_manager@localhost:5432/sport_manager?schema=public"

## ----- Redis -----
REDIS_URL="redis://localhost:6379"

## ----- Runtime -----
NODE_ENV="development"
PORT=3100

## ----- JWT -----
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

## ----- API base URL -----
## Web FE volá API same-origin, takže nic nastavovat netřeba.
## Expo potřebuje plnou URL — přepiš na tunel/LAN adresu Next dev serveru.
EXPO_PUBLIC_API_URL="http://localhost:3100/api/v1"

## ----- Stripe (placeholders) -----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

## ----- Resend (placeholders) -----
RESEND_API_KEY=""
