{
  "expo": {
    "name": "Sport manager",
    "slug": "sport-manager",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "sportmanager",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.qawave.sportmanager"
    },
    "android": {
      "package": "ai.qawave.sportmanager"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
